# Copy to `.env` on the VPS (same directory as docker-compose.api.yml) and fill in.
# docker compose reads this file automatically.
#
# Scenario: API + Postgres on the VPS, front stays on Vercel (cross-origin).

# --- Postgres (local container) ---
POSTGRES_USER=glimmer
POSTGRES_PASSWORD=change_me_long_random
POSTGRES_DB=glimmerlog

# --- Server (Express) ---
JWT_SECRET=change_me_min_32_chars_random_string_here
# Front origin on Vercel — drives CORS allow-origin. MUST be the exact public
# domain the SPA is served from (no trailing slash).
CLIENT_URL=https://glimmerlog.com
GOOGLE_CLIENT_ID=579520504030-1hltphn01kd65ft4keugfp102sgjns16.apps.googleusercontent.com
DISCORD_CLIENT_ID=1483223327827824833
DISCORD_CLIENT_SECRET=your_discord_secret
# Discord OAuth code is exchanged by the FRONT, so the redirect is a front route.
DISCORD_REDIRECT_URI=https://glimmerlog.com/auth/discord/callback
RESEND_API_KEY=your_resend_key
ADMIN_EMAILS=kteisseire@qualigaz-evonia.com

# NOTE: no VITE_* vars here — the client is built & served by Vercel, not the VPS.
# On Vercel, set the env var:  VITE_API_URL=https://api.glimmerlog.com/api/v1
