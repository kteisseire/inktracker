# Copie ce fichier en server\.env et remplis les valeurs.
# Auto-hébergement Windows : API Express + PostgreSQL 17 local.

# --- Base PostgreSQL locale (Postgres 17 déjà installé) ---
# Format : postgresql://UTILISATEUR:MOT_DE_PASSE@localhost:5432/NOM_BASE
DATABASE_URL=postgresql://glimmer:CHANGE_MOI@localhost:5432/glimmerlog

# --- Serveur Express ---
JWT_SECRET=CHANGE_MOI_min_32_caracteres_aleatoires
# Front et API sur le MÊME domaine (Caddy) => origine = le domaine public
CLIENT_URL=https://glimmerlog.com
PORT=3001

# --- OAuth ---
GOOGLE_CLIENT_ID=579520504030-1hltphn01kd65ft4keugfp102sgjns16.apps.googleusercontent.com
DISCORD_CLIENT_ID=1483223327827824833
DISCORD_CLIENT_SECRET=ton_secret_discord
DISCORD_REDIRECT_URI=https://glimmerlog.com/auth/discord/callback

# --- Email (Resend) ---
RESEND_API_KEY=ta_cle_resend

# --- Admin ---
ADMIN_EMAILS=kteisseire@qualigaz-evonia.com

# NOTE : le front se build avec VITE_API_URL=/api/v1 (même origine via Caddy).
# Voir DEPLOY-WINDOWS-SELFHOST.md, étape 6.
